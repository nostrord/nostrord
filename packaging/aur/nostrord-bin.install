post_install() {
  update-desktop-database -q
  xdg-mime default nostrord.desktop x-scheme-handler/nostrord 2>/dev/null || true
  gtk-update-icon-cache -q -f -t /usr/share/icons/hicolor 2>/dev/null || true
}

post_upgrade() {
  post_install
}

post_remove() {
  update-desktop-database -q
  gtk-update-icon-cache -q -f -t /usr/share/icons/hicolor 2>/dev/null || true
}
